  "description": "AI Money Mentor - Financial Management API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:contract": "powershell -ExecutionPolicy Bypass -File ../scripts/run-specmatic-mode.ps1 none",
