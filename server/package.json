{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "specmatic:version": "docker run --rm specmatic/specmatic --version",
    "test:contract": "powershell -ExecutionPolicy Bypass -File ../scripts/run-specmatic-mode.ps1 none",
    "test:resiliency:positive": "powershell -ExecutionPolicy Bypass -File ../scripts/run-specmatic-mode.ps1 positiveOnly",
    "test:resiliency:all": "powershell -ExecutionPolicy Bypass -File ../scripts/run-specmatic-mode.ps1 all",
    "test:specmatic": "powershell -ExecutionPolicy Bypass -File ../scripts/run-specmatic-mode.ps1 none && powershell -ExecutionPolicy Bypass -File ../scripts/run-specmatic-mode.ps1 positiveOnly && powershell -ExecutionPolicy Bypass -File ../scripts/run-specmatic-mode.ps1 all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "google-auth-library": "^9.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.19.3",
    "openai": "^4.72.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
