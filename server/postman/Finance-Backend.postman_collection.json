{
  "info": {
    "name": "Finance Backend API",
    "_postman_id": "0e146eca-6e66-47a4-9e4f-3580a2f87f4f",
    "description": "Collection for auth, users, transactions, and dashboard summary endpoints with RBAC.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo.user@finance.local\",\n  \"password\": \"Demo@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('adminUserId', json.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@finance.local\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Analyst",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('analystToken', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"analyst@finance.local\",\n  \"password\": \"Analyst@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Viewer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('viewerToken', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"viewer@finance.local\",\n  \"password\": \"Viewer@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Create User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Data Viewer\",\n  \"email\": \"data.viewer@finance.local\",\n  \"password\": \"Viewer@123\",\n  \"role\": \"viewer\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/transactions?page=1&limit=10&type=expense"
          }
        },
        {
          "name": "Create Transaction (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json._id) {",
                  "  pm.collectionVariables.set('transactionId', json._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Bonus Payment\",\n  \"notes\": \"Quarterly bonus\",\n  \"amount\": 15000,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-01T00:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/api/transactions"
          }
        },
        {
          "name": "Update Transaction (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 16500,\n  \"notes\": \"Updated amount\"\n}"
            },
            "url": "{{baseUrl}}/api/transactions/{{transactionId}}"
          }
        },
        {
          "name": "Delete Transaction (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/transactions/{{transactionId}}"
          }
        },
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-auth-token",
                "value": "{{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/transactions/summary"
          }
        }
      ]
    },
    {
      "name": "RBAC Checks",
      "item": [
        {
          "name": "Viewer Create Transaction (Should 403)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-auth-token",
                "value": "{{viewerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 999,\n  \"type\": \"expense\",\n  \"category\": \"Test\"\n}"
            },
            "url": "{{baseUrl}}/api/transactions"
          }
        },
        {
          "name": "Analyst List Transactions (Should 200)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-auth-token",
                "value": "{{analystToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/transactions"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "analystToken",
      "value": ""
    },
    {
      "key": "viewerToken",
      "value": ""
    },
    {
      "key": "transactionId",
      "value": ""
    },
    {
      "key": "adminUserId",
      "value": ""
    }
  ]
}
